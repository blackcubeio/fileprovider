{
    "name": "blackcube/fileprovider",
    "description": "File provider with prefix routing and image processing",
    "keywords": [
        "fileprovider",
        "flysystem",
        "filesystem",
        "file-management",
        "upload",
        "image-processing",
        "s3",
        "minio",
        "ftp",
        "sftp",
        "storage"
    ],
    "type": "library",
    "license": "BSD-3-Clause",
    "readme": "README.md",
    "homepage": "https://github.com/blackcubeio/fileprovider",
    "support": {
        "issues": "https://github.com/blackcubeio/fileprovider/issues",
        "source": "https://github.com/blackcubeio/fileprovider"
    },
    "authors": [
        {
            "name": "Philippe Gaultier",
            "email": "philippe@blackcube.io"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "league/flysystem": "^3.32"
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "^3.3",
        "codeception/module-filesystem": "^3.0",
        "codeception/module-phpbrowser": "^4.0",
        "codeception/module-rest": "^3.4",
        "intervention/image": "^3.11",
        "league/flysystem-aws-s3-v3": "^3.32",
        "league/flysystem-ftp": "^3.31",
        "league/flysystem-sftp-v3": "^3.31",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "vlucas/phpdotenv": "^5.6",
        "yiisoft/aliases": "^3.1",
        "yiisoft/data-response": "^2.2",
        "yiisoft/di": "^1.4",
        "yiisoft/http": "^1.3",
        "yiisoft/test-support": "^3.2"
    },
    "suggest": {
        "league/flysystem-aws-s3-v3": "Required for S3/MinIO storage",
        "league/flysystem-ftp": "Required for FTP storage",
        "league/flysystem-sftp-v3": "Required for SFTP storage",
        "intervention/image": "Required for image processors (resize, watermark, etc.)"
    },
    "autoload": {
        "psr-4": {
            "Blackcube\\FileProvider\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blackcube\\FileProvider\\Tests\\": "tests"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-devel": "1.x-dev"
        },
        "config-plugin-file": "config/configuration.php"
    },
    "config": {
        "sort-packages": true
    }
}
